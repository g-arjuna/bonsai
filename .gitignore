/target

# Runtime config — contains credentials, never commit
bonsai.toml

# LadybugDB graph database files
bonsai.db
bonsai.db.wal
bonsai-mv.db
bonsai-mv.db.wal

# ContainerLab runtime directories (TLS certs, node configs, topology state)
lab/**/clab-*

# Generated protobuf — work from .proto sources, not generated output
src/proto/

# ContainerLab CA certs (generated per deployment, not committed)
lab/fast-iteration/ca.pem
lab/fast-iteration/mv-ca.pem

# gNMI probe credentials (copy from gnmi-creds.sh.example)
lab/tools/gnmi-creds.sh

# ContainerLab p4 CA cert (generated per deployment)
lab/fast-iteration/p4-ca.pem

# Python bytecode and caches
__pycache__/
*.py[cod]
*.pyo

# Trained ML model binaries (large, runtime-generated — train locally)
python/models/
models/

# Training data exports (large Parquet files, runtime-generated)
data/

# Svelte UI build output and dependencies (reproducible from source)
ui/dist/
ui/node_modules/

# Debug / run logs
*.log

# Claude Code session memory (local tooling state, not project content)
.claude/
ui/.vscode/
