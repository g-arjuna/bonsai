# bonsai.toml — runtime configuration
# Copy to bonsai.toml, fill in credentials, keep out of git (it is gitignored).
# Never commit credentials.
#
# Phase 4 lab: bonsai-p4 (3x SRL + 1x XRd, mgmt 172.100.102.x)
# Run lab/fast-iteration/deploy-p4.sh to generate p4-ca.pem and bring up nodes.

graph_path   = "bonsai.db"
# Runtime mode (T1-2 distributed collector seam)
# [runtime]
# mode = "all"  # one of: all, core, collector
# collector_id = "local"
# core_ingest_endpoint = "http://[::1]:50051"  # used only by collector mode
# [runtime.tls]
# enabled = false
# ca_cert = "config/tls/ca.pem"
# cert = "config/tls/core.pem"       # core cert in core/all mode; collector cert in collector mode
# key = "config/tls/core-key.pem"
# server_name = "bonsai-core.local"  # collector-side verification name; must match core SAN
#
# all: current single-process behavior; subscribes to devices and runs graph/API/UI.
# core: graph/API/UI plus TelemetryIngest server; no local gNMI subscribers.
# collector: local gNMI subscribers plus optional collector-local archive; forwards
# decoded telemetry to the core ingest endpoint.
# api_addr     = "[::1]:50051"   # gRPC API (default shown)
# metrics_addr = "[::1]:9090"    # Prometheus /metrics HTTP (set to "" to disable)
#
# [collector.queue]
# path = "runtime/collector-queue"
# max_bytes = 1073741824       # 1 GiB; oldest unacked records are dropped above this
# max_age_hours = 24           # 0 disables age-based drops
# drain_batch_size = 1000      # records per reconnect replay stream
# log_interval_seconds = 30    # periodic queue size visibility; 0 disables

# Local credential vault (T1-1). Set BONSAI_VAULT_PASSPHRASE before starting
# Bonsai to unlock alias-based credentials. Secrets are encrypted in vault.age;
# metadata.json stores alias names and timestamps only.
# [credentials]
# path = "bonsai-credentials"
# passphrase_env = "BONSAI_VAULT_PASSPHRASE"

# ── Graph database (v12 T0-1) ─────────────────────────────────────────────────
# LadybugDB buffer pool is capped by default to avoid the ~80% RAM grab.
# Default: min(2 GiB, 25% of RAM) for core; min(256 MiB, 10%) for collector.
# Override here if you have more RAM to spare or run on a constrained device.
# [graph]
# buffer_pool_bytes = 2147483648   # 2 GiB — safe for 16 GB machines with a 4-device lab

# ── Event bus (T1-1) ──────────────────────────────────────────────────────────
# [event_bus]
# capacity              = 512    # broadcast channel depth; default reduced from 2048 in v12
# counter_debounce_secs = 10     # min interval between interface counter graph writes
# [archive]
# enabled                = true     # write telemetry updates to parquet for cold storage
# path                   = "archive"
# flush_interval_seconds = 10
# max_batch_rows         = 1000
# compression_level      = 12        # ZSTD level 1-22 (default 12; level 22 not worth CPU cost)
# writer_max_idle_secs   = 7200      # force-close partition writers idle for >2h (prevents open-file leaks)

# ── Retention (v11 T4-3) ─────────────────────────────────────────────────────
# Enabled by default to bound graph memory and WAL size.
# [retention]
# enabled                  = true    # enable hourly prune pass (default: true)
# max_age_hours            = 24      # delete events older than N hours (default: 24)
# max_state_change_events  = 10000   # hard cap on total events; 0 = unlimited (default: 10000)

# ── Storage caps (v11 T4-5) ──────────────────────────────────────────────────
# [storage]
# max_archive_bytes     = 10737418240   # 10 GB archive cap (0 = unlimited)
# max_graph_bytes       = 5368709120    # 5 GB graph cap (0 = unlimited)
# check_interval_secs   = 300           # how often to check disk usage
# warn_threshold_pct    = 80            # warn when usage reaches this % of cap

# ── ServiceNow integration (T2-1) ─────────────────────────────────────────────
# Primary dev/test target: your reserved PDI (https://devXXXXXX.service-now.com).
# Production deployments: use scoped roles (itil + event_creator), NOT admin creds.
# Credential is stored in the vault under `credential_alias` — NEVER inline here.
#
# [integrations.servicenow]
# enabled           = false
# instance_url      = "https://devXXXXXX.service-now.com"
# credential_alias  = "servicenow-pdi"   # set with: bonsai credentials set servicenow-pdi
# em_push_enabled   = false              # push DetectionEvents to Event Management
#
# [integrations.servicenow.event_filter]
# min_severity       = "warning"   # "critical" | "warning" | "info"
# min_age_secs       = 60          # only push detections older than N seconds (debounce transients)
# dedup_window_secs  = 300         # suppress same (device, rule) re-push within N seconds

# ── Human-in-the-loop remediation trust (Sprint 4) ────────────────────────────
# [remediation]
# rollback_window_secs = 60
#
# [remediation.graduation]
# consecutive_approvals_required = 10
#
# [remediation.defaults]
# home_lab         = "auto_silent"
# data_center      = "auto_with_notification"
# service_provider = "approve_each"
# campus_wired     = "auto_with_notification"
# campus_wireless  = "approve_each"
#
# Optional per-rule overrides. Unspecified archetypes inherit the global default.
# [remediation.rule_defaults.bgp_session_down]
# data_center      = "approve_each"
# service_provider = "approve_each"

# ── Nokia SR Linux — spine (TLS) ─────────────────────────────────────────────
[[target]]
address    = "172.100.102.11:57400"
hostname   = "srl-spine1"
tls_domain = "clab-bonsai-p4-srl-spine1"
ca_cert    = "lab/fast-iteration/p4-ca.pem"
# credential_alias = "srl-lab-admin"  # preferred once added via /api/credentials
username   = "admin"
password   = "NokiaSrl1!"

# ── Nokia SR Linux — leaf1 (TLS) ─────────────────────────────────────────────
[[target]]
address    = "172.100.102.12:57400"
hostname   = "srl-leaf1"
tls_domain = "clab-bonsai-p4-srl-leaf1"
ca_cert    = "lab/fast-iteration/p4-ca.pem"
username   = "admin"
password   = "NokiaSrl1!"

# ── Nokia SR Linux — leaf2 (TLS) ─────────────────────────────────────────────
[[target]]
