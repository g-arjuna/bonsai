# bonsai.toml — runtime configuration
# Copy to bonsai.toml, fill in credentials, keep out of git (it is gitignored).
# Never commit credentials.
#
# Phase 4 lab: bonsai-p4 (3x SRL + 1x XRd, mgmt 172.100.102.x)
# Run lab/fast-iteration/deploy-p4.sh to generate p4-ca.pem and bring up nodes.

graph_path = "bonsai.db"

# ── Nokia SR Linux — spine (TLS) ─────────────────────────────────────────────
[[target]]
address    = "172.100.102.11:57400"
hostname   = "srl-spine1"
tls_domain = "clab-bonsai-p4-srl-spine1"
ca_cert    = "lab/fast-iteration/p4-ca.pem"
username   = "admin"
password   = "NokiaSrl1!"

# ── Nokia SR Linux — leaf1 (TLS) ─────────────────────────────────────────────
[[target]]
address    = "172.100.102.12:57400"
hostname   = "srl-leaf1"
tls_domain = "clab-bonsai-p4-srl-leaf1"
ca_cert    = "lab/fast-iteration/p4-ca.pem"
username   = "admin"
password   = "NokiaSrl1!"

# ── Nokia SR Linux — leaf2 (TLS) ─────────────────────────────────────────────
[[target]]
address    = "172.100.102.13:57400"
hostname   = "srl-leaf2"
tls_domain = "clab-bonsai-p4-srl-leaf2"
ca_cert    = "lab/fast-iteration/p4-ca.pem"
username   = "admin"
password   = "NokiaSrl1!"

# ── Cisco IOS-XRd — PE (no TLS) ──────────────────────────────────────────────
[[target]]
address  = "172.100.102.21:57400"
hostname = "xrd-pe1"
username = "cisco"
password = "cisco123!"
