# Copy this file to .env and fill in the values before running docker compose.
# .env is gitignored — never commit it.
#
# Quick start (bonsai core + external services):
#   cp .env.example .env
#   # Edit .env: set BONSAI_VAULT_PASSPHRASE, SPLUNK_PASSWORD, SPLUNK_HEC_TOKEN, ELASTIC_PASSWORD
#   scripts/generate_compose_tls.sh
#   docker compose -f docker/compose-external.yml --profile all up -d
#   scripts/seed_external.sh
#   scripts/check_external.sh
#   docker compose --profile two-collector up -d
#   scripts/seed_lab_creds.sh   # first time only

# ── Core ──────────────────────────────────────────────────────────────────────

# Passphrase for the bonsai credential vault.
# Must be set — compose will refuse to start without it.
# Use a long random string (e.g. openssl rand -base64 32).
BONSAI_VAULT_PASSPHRASE=

# ContainerLab network name. Must match the Docker network created by `clab deploy`.
# Format: clab-<topology-name>  (e.g. clab-fast-iteration, clab-bonsai-lab)
# Default: clab-bonsai-lab
# CLAB_NETWORK=bonsai-p4-mgmt

# ── NetBox (auto-set by compose; override only if customising) ────────────────

NETBOX_API_TOKEN=bonsai-dev-token

# ── Splunk (required if using --profile splunk or --profile all) ──────────────

# Admin password for the Splunk web UI (http://localhost:8100, admin/<SPLUNK_PASSWORD>)
SPLUNK_PASSWORD=

# HEC token used by bonsai to forward events to Splunk.
# Also used by seed_splunk.py and e2e_output_adapters_test.sh.
# Generate with: openssl rand -hex 16
SPLUNK_HEC_TOKEN=

# ── Elasticsearch (required if using --profile elastic or --profile all) ──────

# Password for the elastic built-in user (only if xpack.security.enabled=true).
# Default compose config has security disabled for dev — leave blank.
ELASTIC_PASSWORD=

# ── ServiceNow PDI (operator-provided; PDIs are personal cloud instances) ─────

# Provision a free PDI at https://developer.servicenow.com
# Leave blank to skip ServiceNow seeding.
SNOW_INSTANCE_URL=
SNOW_USERNAME=admin
SNOW_PASSWORD=

# ── Optional chaos profile tunables ──────────────────────────────────────────

# CHAOS_DELAY_MS=500
# CHAOS_DURATION=5m
