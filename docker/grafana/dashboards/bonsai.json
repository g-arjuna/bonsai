{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "Bonsai network state engine — interface telemetry, detection events, and runtime health",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 10,
      "title": "Interface Telemetry",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10},
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "id": 1,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "expr": "rate(bonsai_interface_in_octets_total[2m]) * 8",
          "legendFormat": "{{hostname}} {{interface}} in",
          "refId": "A"
        }
      ],
      "title": "Interface Input (bps)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10},
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "id": 2,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "expr": "rate(bonsai_interface_out_octets_total[2m]) * 8",
          "legendFormat": "{{hostname}} {{interface}} out",
          "refId": "A"
        }
      ],
      "title": "Interface Output (bps)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 11,
      "title": "Detections",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 1},
            {"color": "red", "value": 5}
          ]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 10},
      "id": 3,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [
        {
          "expr": "sum(increase(bonsai_detection_events_total[1h])) or vector(0)",
          "legendFormat": "Detections (1h)",
          "refId": "A"
        }
      ],
      "title": "Detection Events (last 1h)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 18, "x": 6, "y": 10},
      "id": 4,
      "options": {"legend": {"calcs": ["sum"], "displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "expr": "increase(bonsai_detection_events_total[5m])",
          "legendFormat": "{{rule_name}}",
          "refId": "A"
        }
      ],
      "title": "Detection Events by Rule (5m windows)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 12,
      "title": "Runtime Health",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10},
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "id": 5,
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"bonsai\"}",
          "legendFormat": "RSS",
          "refId": "A"
        }
      ],
      "title": "Bonsai Memory (RSS)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 19},
      "id": 6,
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "expr": "bonsai_telemetry_updates_total",
          "legendFormat": "Total telemetry updates",
          "refId": "A"
        },
        {
          "expr": "bonsai_active_subscriptions",
          "legendFormat": "Active subscriptions",
          "refId": "B"
        }
      ],
      "title": "Telemetry Pipeline",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["bonsai", "network", "telemetry"],
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Bonsai — Network State Engine",
  "uid": "bonsai-main",
  "version": 1
}
